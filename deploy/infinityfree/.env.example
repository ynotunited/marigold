# Application
APP_NAME="Marigold Signature Nigeria Limited"
APP_URL=https://your-subdomain.epizy.com
APP_ENV=production
APP_DEBUG=false
APP_KEY=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING
APP_TIMEZONE=Africa/Lagos

# Database
DB_HOST=sqlXXX.infinityfree.com
DB_PORT=3306
DB_NAME=epiz_XXXXXXXX_marigold
DB_USER=epiz_XXXXXXXX
DB_PASS=your_database_password

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME="Marigold Signature"
SMTP_FROM_EMAIL=hello@marigoldsignature.com

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_or_test_key
PAYSTACK_SECRET_KEY=sk_live_or_test_key
PAYSTACK_CALLBACK_URL=https://your-subdomain.epizy.com/payment/callback

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel
META_PIXEL_ID=

# WhatsApp
WHATSAPP_NUMBER=234XXXXXXXXXX

# Storage
UPLOAD_MAX_SIZE=20971520
UPLOAD_PATH=../public_html/uploads

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600

# Session
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
